## API Calls

Use the `apiConnect` singleton from `client/data/ApiConnect`:

```typescript
import apiConnect from 'client/data/ApiConnect';

// In a component or effect
const loadData = async () => {
  const expenses = await apiConnect.getExpensesForMonth(year, month);
  setExpenses(expenses);
};

// Create/update
const handleSave = async (data: ExpenseData) => {
  await apiConnect.storeExpense(data);
};
```

## Async Data Loading

Use the custom hooks from `src/client/ui/hooks/`:

```typescript
import { useAsyncData } from './hooks/useAsyncData';

export const MyComponent: React.FC<Props> = ({ id }) => {
  const dataState = useAsyncData(
    () => apiConnect.getItem(id),
    id !== undefined,
    id,
  );

  switch (dataState.type) {
    case 'loaded':
      return <DisplayData data={dataState.value} />;
    case 'error':
      return <ErrorView error={dataState.error} />;
    default:
      return <LoadingSpinner />;
  }
};
```

## Reactive State (Bacon.js)

For components that need reactive data streams:

```typescript
import { connect } from '../component/BaconConnect';
import { userDataE, UserDataProps } from 'client/data/Categories';

interface MyProps extends UserDataProps {
  additionalProp: string;
}

const MyComponent: React.FC<MyProps> = ({ userData, additionalProp }) => {
  // userData is automatically provided via the stream
  return <div>{userData.categories.map(/* ... */)}</div>;
};

export default connect(userDataE.map(userData => ({ userData })))(MyComponent);
```

## State Management (Zustand)

For simpler state needs, prefer Zustand:

```typescript
import { create } from 'zustand';

interface MyStore {
  items: Item[];
  addItem: (item: Item) => void;
  removeItem: (id: number) => void;
}

export const useMyStore = create<MyStore>((set) => ({
  items: [],
  addItem: (item) => set((state) => ({ items: [...state.items, item] })),
  removeItem: (id) => set((state) => ({ 
    items: state.items.filter(i => i.id !== id) 
  })),
}));
```

