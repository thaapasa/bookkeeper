{
  "name": "bookkeeper",
  "version": "0.9.2",
  "main": "src/server/BookkeeperServer.ts",
  "description": "Kukkaro - a web tool for tracking your income and expenses.",
  "private": true,
  "scripts": {
    "postinstall": "bun run install-sharp && bun run update-revisions",
    "install-sharp": "cd node_modules/sharp && bun install",
    "dev-db": "docker compose -f docker-compose.dev.yml up -d",
    "dev-db-stop": "docker compose -f docker-compose.dev.yml down",
    "ui": "bun run update-revision client && vite",
    "server": "bun run update-revision server && bun run migrate && bun run --watch src/server/BookkeeperServer.ts | bun pretty-log",
    "build-client": "vite build",
    "build-server": "NODE_ENV=production bun run src/build-server.ts",
    "update-revision": "bash script/update-revision.sh",
    "update-revisions": "bun run update-revision server && bun run update-revision client",
    "pretty-log": "bun --bun pino-pretty --config .pino-prettyrc.js",
    "lint": "bun lint-eslint && bun lint-tsc",
    "lint-eslint": "eslint src",
    "lint-tsc": "tsc --noEmit",
    "format": "eslint --fix src",
    "clean": "rm -rf build/ dist/ build-server/",
    "start-server": "./script/start-server.sh",
    "migrate": "knex migrate:latest",
    "migrate-make": "knex migrate:make",
    "dump-schema": "pg_dump --schema-only --no-owner --no-privileges --no-comments $(grep '^DB_URL=' .env | cut -d= -f2-) | grep -v '^\\\\restrict\\|^\\\\unrestrict' > docs/SCHEMA.sql",
    "rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "example-data": "bun run src/tools/addExampleData.ts",
    "find-cyclic": "bunx madge --extensions ts,tsx --circular ."
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:thaapasa/bookkeeper.git"
  },
  "author": "Anu & Tuukka Haapasalo",
  "license": "ISC",
  "homepage": "https://kukkaro.pomeranssi.fi",
  "dependencies": {
    "@mantine/core": "^9.0.1",
    "@mantine/dates": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@mantine/notifications": "^9.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation-express": "^0.62.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-query-devtools": "^5.97.0",
    "big.js": "7.0.1",
    "dayjs": "^1.11.20",
    "dotenv": "17.4.1",
    "express": "5.2.1",
    "knex": "3.2.9",
    "lucide-react": "^1.7.0",
    "luxon": "^3.7.2",
    "nocache": "4.0.0",
    "parse-multipart-data": "1.5.0",
    "pg": "8.20.0",
    "pg-promise": "12.6.2",
    "pino": "10.3.1",
    "pino-loki": "^3.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.14.0",
    "react-router-dom": "7.14.0",
    "recharts": "3.8.1",
    "sharp": "0.34.5",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/big.js": "6.2.2",
    "@types/express": "5.0.6",
    "@types/luxon": "^3.7.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "@vitejs/plugin-react": "6.0.1",
    "bun-types": "1.3.11",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "vite": "8.0.5"
  },
  "trustedDependencies": [
    "protobufjs",
    "sharp"
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
